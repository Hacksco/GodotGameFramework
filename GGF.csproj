<Project Sdk="Godot.NET.Sdk/4.6.2">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>GGF</RootNamespace>
    <!-- 启用 unsafe 代码块，Utility.Converter.cs 中有指针操作需要此选项 -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- 禁用自动生成 AssemblyInfo 特性，因为 Properties/AssemblyInfo.cs 已手动定义 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- 日志编译开关（与 UGF 对齐）：
         定义 ENABLE_LOG 启用所有日志输出。
         可用更精细的符号控制级别：ENABLE_DEBUG_LOG / ENABLE_INFO_LOG / ENABLE_WARNING_LOG / ENABLE_ERROR_LOG / ENABLE_FATAL_LOG
         以及分级开关：ENABLE_DEBUG_AND_ABOVE_LOG / ENABLE_INFO_AND_ABOVE_LOG 等。
         Release 构建时可移除此行以消除所有日志调用的性能开销。 -->
    <DefineConstants>$(DefineConstants);ENABLE_LOG</DefineConstants>
  </PropertyGroup>
</Project>
