[gd_scene format=3]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.08, 0.12, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -160.0
offset_right = 220.0
offset_bottom = 160.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 36
text = "Click The Blocks!"
horizontal_alignment = 1

[node name="Spacer1" type="Control" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 16)

[node name="Subtitle" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "GGF Demo Game"
horizontal_alignment = 1

[node name="PhaseLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Phase 1-5 Feature Demonstration"
horizontal_alignment = 1

[node name="Spacer2" type="Control" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)

[node name="Rules" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Green: +10 | Red: -5 (3s) | 30 seconds | Esc: Pause"
horizontal_alignment = 1

[node name="Features" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
text = "Log Event FSM Procedure Config DataTable Setting DataNode ObjectPool Resource Entity UI(UIItem)"
horizontal_alignment = 1

[node name="Spacer4" type="Control" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)

[node name="StartButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(180, 44)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 18
text = "Start Game"

[node name="Spacer5" type="Control" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="LanguageButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(120, 36)
size_flags_horizontal = 4
theme_override_font_sizes/font_size = 14
text = "中文 / English"
